{
  "name": "node-api-platform",
  "version": "1.0.0",
  "description": "Production-ready Node.js REST API with Express.js, security best practices, and comprehensive error handling",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix"
  },
  "keywords": ["api", "rest", "express", "node", "backend"],
  "author": "Adonis Jimenez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mr-adonis-jimenez/node-api-platform.git"
  },
  "bugs": {
    "url": "https://github.com/mr-adonis-jimenez/node-api-platform/issues"
  },
  "homepage": "https://github.com/mr-adonis-jimenez/node-api-platform#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.8.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  }
}
